#!/bin/sh

KEENSNAP_DIR="/opt/root/KeenSnap"
CONFIG_DIR="/opt/etc/keensnap"
SCRIPT="$KEENSNAP_DIR/keensnap.sh"
INIT_SCRIPT="$KEENSNAP_DIR/keensnap-init"
LEGACY_CONFIG_FILE="$KEENSNAP_DIR/config.sh"
OLD_CONFIG_FILE="$KEENSNAP_DIR/config.conf"
OLD_DEFAULT_CONFIG_FILE="$KEENSNAP_DIR/defaults.conf"
DEFAULT_CONFIG_FILE="$CONFIG_DIR/defaults.conf"
CONFIG_FILE="$CONFIG_DIR/config.conf"
BIN_LINK="/opt/bin/keensnap"
CRON_FILE="/opt/etc/crontab"
CRON_MARKER="# KeenSnap"
RED='\033[1;31m'
GREEN='\033[1;32m'
NC='\033[0m'

print_message() {
  local message=$1
  local color=${2:-$NC}
  local border=$(printf '%0.s-' $(seq 1 $((${#message} + 2))))
  printf "${color}\n+${border}+\n| ${message} |\n+${border}+\n${NC}\n"
}

install_s3cmd() {
  if command -v s3cmd >/dev/null 2>&1; then
    return 0
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    print_message "python3 не найден, s3cmd не установлен" "$RED"
    return 0
  fi

  if ! python3 -m pip --version >/dev/null 2>&1; then
    print_message "python3-pip не найден, s3cmd не установлен" "$RED"
    return 0
  fi

  print_message "Устанавливаю s3cmd через pip" "$GREEN"
  if ! python3 -m pip install --no-cache-dir s3cmd; then
    print_message "Не удалось установить s3cmd через pip. S3-отправка будет недоступна." "$RED"
  fi
}

mkdir -p "$KEENSNAP_DIR"
mkdir -p "$CONFIG_DIR"
mkdir -p "$(dirname "$BIN_LINK")"

if [ -d "/opt/opt/root/KeenSnap" ] && [ ! -f "$SCRIPT" ]; then
  cp -f /opt/opt/root/KeenSnap/keensnap.sh "$SCRIPT" 2>/dev/null || true
  cp -f /opt/opt/root/KeenSnap/keensnap-init "$INIT_SCRIPT" 2>/dev/null || true
  cp -f /opt/opt/root/KeenSnap/defaults.conf "$DEFAULT_CONFIG_FILE" 2>/dev/null || true
  cp -f /opt/opt/root/KeenSnap/config.conf "$CONFIG_FILE" 2>/dev/null || true
fi

if [ -f "/opt/opt/bin/keensnap" ] && [ ! -f "$BIN_LINK" ]; then
  cp -f /opt/opt/bin/keensnap "$BIN_LINK" 2>/dev/null || true
fi

chmod +x "$SCRIPT" 2>/dev/null
chmod +x "$INIT_SCRIPT" 2>/dev/null
chmod +x "$BIN_LINK" 2>/dev/null

if [ -f "$LEGACY_CONFIG_FILE" ]; then
  mv -f "$LEGACY_CONFIG_FILE" "$CONFIG_FILE"
elif [ -f "$OLD_CONFIG_FILE" ] && ! grep -q '^[A-Za-z_][A-Za-z0-9_]*=' "$CONFIG_FILE" 2>/dev/null; then
  mv -f "$OLD_CONFIG_FILE" "$CONFIG_FILE"
fi

rm -f "$OLD_DEFAULT_CONFIG_FILE"

install_s3cmd

if [ ! -x "$BIN_LINK" ]; then
  printf '%s\n' '#!/bin/sh' 'exec /opt/root/KeenSnap/keensnap.sh "$@"' >"$BIN_LINK"
  chmod +x "$BIN_LINK"
fi
rm -f "/opt/etc/ndm/schedule.d/99-keensnap.sh"

if [ -f "$CONFIG_FILE" ]; then
  [ -f "$DEFAULT_CONFIG_FILE" ] && . "$DEFAULT_CONFIG_FILE"
  . "$CONFIG_FILE"
  mkdir -p "$(dirname "$CRON_FILE")"
  touch "$CRON_FILE"
  sed -i "\|$CRON_MARKER|d" "$CRON_FILE"
  if [ -n "$CRON_SCHEDULE" ]; then
    set -f
    set -- $CRON_SCHEDULE
    set +f
    if [ "$#" -eq 5 ]; then
      printf '%s %s start cron %s\n' "$CRON_SCHEDULE" "$INIT_SCRIPT" "$CRON_MARKER" >>"$CRON_FILE"
    else
      print_message "CRON_SCHEDULE должен содержать 5 cron-полей" "$RED"
    fi
  fi
  if [ -x "/opt/etc/init.d/S10cron" ]; then
    /opt/etc/init.d/S10cron restart >/dev/null 2>&1 || /opt/etc/init.d/S10cron start >/dev/null 2>&1
  elif command -v crond >/dev/null 2>&1; then
    killall crond >/dev/null 2>&1
    crond >/dev/null 2>&1
  fi
fi

print_message  "Пакет установлен, настройте $CONFIG_FILE и запустите keensnap" "$GREEN"
exit 0
